---
layout: base.liquid
title: Projects
navTitle: Projects
permalink: /projects/
subtitle: >-
  Research and student innovation projects I've led, contributed to, or advised —
  organized by year, with the funding behind each where applicable.
---

{% assign totalProjects = 0 %}
{% for group in projects.groups %}
    {% assign totalProjects = totalProjects | plus: group.items.size %}
{% endfor %}

<header class="page-header">
    <p class="page-header-kicker kicker">Index of projects</p>
    <h1 class="page-header-title">Projects<span class="title-dot">.</span></h1>
    <p class="page-header-subtitle">{{ subtitle }}</p>
    <div class="page-header-meta">
        <span class="page-header-stat"><i class="fas fa-diagram-project" aria-hidden="true"></i> {{ totalProjects }} projects</span>
        {% for group in projects.groups %}
        <span class="page-header-stat">{{ group.year }} &middot; {{ group.items.size }}</span>
        {% endfor %}
    </div>
</header>

<div class="pubs-layout">
    <div class="pubs-stream">
        {% for group in projects.groups %}
        <section id="year-{{ group.year }}" class="year-section" data-year="{{ group.year }}">
            <span class="year-ghost" aria-hidden="true">{{ group.year }}</span>
            <header class="year-head">
                <h2 class="year-num">{{ group.year }}</h2>
                <span class="year-count"><b>{{ group.items.size }}</b> project{% if group.items.size > 1 %}s{% endif %}</span>
                <span class="year-rule" aria-hidden="true"></span>
            </header>

            <div class="project-list">
                {% for item in group.items %}
                    {% include "project-item" %}
                {% endfor %}
            </div>
        </section>
        {% endfor %}
    </div>

    <aside class="pubs-rail" aria-label="Jump to year">
        <div class="rail-label">Timeline</div>
        <nav class="rail-nav" id="year-rail">
            {% for group in projects.groups %}
            <a class="rail-link" href="#year-{{ group.year }}">
                {{ group.year }}
                <span class="rail-count">{{ group.items.size }}</span>
            </a>
            {% endfor %}
        </nav>
    </aside>
</div>
