<!DOCTYPE html>
<html lang="en">

<head>
    {% include "head" %}
</head>
<body>
    <svg class="lq-defs" aria-hidden="true" focusable="false" width="0" height="0">
        <defs>
            <filter id="liquid-distortion" x="-25%" y="-25%" width="150%" height="150%" color-interpolation-filters="sRGB">
                <feTurbulence type="fractalNoise" baseFrequency="0.006 0.011" numOctaves="2" seed="7" result="n"></feTurbulence>
                <feGaussianBlur in="n" stdDeviation="2.2" result="b"></feGaussianBlur>
                <feDisplacementMap in="SourceGraphic" in2="b" scale="16" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
            </filter>
            <filter id="liquid-distortion-strong" x="-25%" y="-25%" width="150%" height="150%" color-interpolation-filters="sRGB">
                <feTurbulence type="fractalNoise" baseFrequency="0.008 0.014" numOctaves="2" seed="11" result="n"></feTurbulence>
                <feGaussianBlur in="n" stdDeviation="2" result="b"></feGaussianBlur>
                <feDisplacementMap in="SourceGraphic" in2="b" scale="28" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
            </filter>
        </defs>
    </svg>

    <div class="canvas-glow" aria-hidden="true"></div>
    <div class="canvas-veil" aria-hidden="true"></div>
    <div class="canvas-grain" aria-hidden="true"></div>

    {% include "navbar" %}

    <main class="page-main">
        <div class="shell">
            {{ content }}
        </div>
    </main>

    {% include "footer" %}

    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" integrity="sha384-7zkQWkzuo3B5mTepMUcHkMB5jZaolc2xDwL6VFqjFALcbeS9Ggm/Yr2r3Dy4lfFg" crossorigin="anonymous"></script>
    <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" integrity="sha384-43gviWU0YVjaDtb/GhzOouOXtZMP/7XUzwPTstBeZFe/+rCMvRwr4yROQP43s0Xk" crossorigin="anonymous"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            if (typeof renderMathInElement === "function") {
                renderMathInElement(document.body, {
                    delimiters: [
                        { left: '$$', right: '$$', display: true },
                        { left: '$', right: '$', display: false }
                    ],
                    throwOnError: false
                });
            }
        });
    </script>

    <script src="/scripts/site.js" defer></script>
    <script src="/scripts/citations.js" defer></script>
</body>
</html>
