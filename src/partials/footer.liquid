<footer class="site-footer">
    <div class="shell">
        <div class="footer-base">
            <div class="footer-note">{{ display.footer_text }}</div>
            <div class="footer-meta">
                <span>&copy; {{ "now" | date: "%Y" }} {{ profile.primary_name }}</span>
                <span class="sep" aria-hidden="true">&#10038;</span>
                <span>Updated {{ "now" | date: "%b %Y" }}</span>
            </div>
        </div>
    </div>
</footer>
