<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="description" content="{{ profile.short_bio | strip_html | strip_newlines | truncatewords: 30 }}">
<meta name="author" content="{{ profile.primary_name }}">
<title>{{ title }} - {{ profile.navbar_name }}</title>
<link rel="icon" type="image/png" href="/favicon.png">

<meta property="og:type" content="profile">
<meta property="og:title" content="{{ title }} - {{ profile.navbar_name }}">
<meta property="og:description" content="{{ profile.short_bio | strip_html | strip_newlines | truncatewords: 30 }}">
{% if profile.portrait_url %}<meta property="og:image" content="{{ profile.portrait_url }}">{% endif %}
<meta name="twitter:card" content="summary">
<meta name="theme-color" id="meta-theme-color" content="#f7f4ec">

<script>
    (function () {
        var theme = "light";
        try {
            var stored = localStorage.getItem("theme");
            theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        } catch (e) {}
        document.documentElement.setAttribute("data-theme", theme);
        var meta = document.getElementById("meta-theme-color");
        if (meta) meta.setAttribute("content", theme === "dark" ? "#14120e" : "#f7f4ec");
    })();
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500..900;1,9..144,500..900&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400..700;1,8..60,400..600&display=swap" rel="stylesheet">

